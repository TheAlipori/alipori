---
import Layout from "../../layouts/Layout.astro";
import PortfolioHero from "../../components/PortfolioHero.astro";
import CaseStudy from "../../components/CaseStudy.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import CallToAction from "../../components/CallToAction.astro";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="Pori - Portfolio">
  <PortfolioHero />

  <!-- CopyMax Case Study -->
  <CaseStudy
    subtitle={t("case_copymax_subtitle")}
    title={t("case_copymax_title")}
    description={t("case_copymax_description")}
    technologies={[
      "Python",
      "React",
      "Astro",
      "Tailwind CSS",
      "Figma",
      "Adobe illustrator",
    ]}
    mainImage="/copymaxlandingpage.png"
    sideImage1="/copymaxlandingpage.png"
    sideImage2="/copymaxlandingpage.png"
    showAction={false}
  />

  <!-- CIML Case Study -->
  <CaseStudy
    subtitle={t("case_ciml_subtitle")}
    title={t("case_ciml_title")}
    description={t("case_ciml_description")}
    technologies={[
      "Astro",
      "Tailwind CSS",
      "Figma",
    ]}
    mainImage="/ciml.webp"
    sideImage1="/ciml-screenshot1.webp"
    sideImage2="/ciml-screenshot1.webp"
    sideImage1Position="object-top"
    sideImage2Position="object-bottom"
    showAction={false}
  />

  <!-- Add more case studies here -->

  <CallToAction />
</Layout>
