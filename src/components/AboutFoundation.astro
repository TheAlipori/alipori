---
interface Props {
  lang: string;
}

const { lang } = Astro.props;

import { useTranslations } from "../i18n/utils";
const t = useTranslations(lang);
---

<section class="relative py-20 px-4 md:px-10 overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <!-- Main Title -->
    <div class="text-center mb-16" data-aos="fade-up" data-aos-duration="1000">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        <span class="bg-gradient-to-r from-white via-purple-200 to-blue-200 bg-clip-text text-transparent">
          {t("about_foundation_title")}
        </span>
      </h2>
      <p class="text-lg md:text-xl text-white/80 max-w-3xl mx-auto leading-relaxed">
        {t("about_foundation_subtitle")}
      </p>
    </div>

    <!-- Content Grid -->
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left Column - Mission & Philosophy -->
      <div class="space-y-12">
        <!-- Mission -->
        <div data-aos="fade-right" data-aos-duration="1000" data-aos-delay="200">
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-6">
            {t("about_mission_title")}
          </h3>
          <p class="text-white/80 text-lg leading-relaxed mb-6">
            {t("about_mission_text")}
          </p>
          <p class="text-white/80 text-lg leading-relaxed">
            {t("about_mission_text2")}
          </p>
        </div>

        <!-- Numbers Section -->
        <div 
          data-aos="fade-right" 
          data-aos-duration="1000" 
          data-aos-delay="400"
          class="bg-gradient-to-br from-purple-900/30 to-blue-900/30 backdrop-blur-sm rounded-2xl p-8 border border-white/10"
        >
          <h4 class="text-xl font-bold text-white mb-6">{t("about_numbers_title")}</h4>
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center">
              <div class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent mb-2">
                100%
              </div>
              <div class="text-white/70 text-sm">{t("about_number1")}</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent mb-2">
                5+
              </div>
              <div class="text-white/70 text-sm">{t("about_number2")}</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent mb-2">
                1-on-1
              </div>
              <div class="text-white/70 text-sm">{t("about_number3")}</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent mb-2">
                100%
              </div>
              <div class="text-white/70 text-sm">{t("about_number4")}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column - Advantages -->
      <div class="space-y-8">
        <div data-aos="fade-left" data-aos-duration="1000" data-aos-delay="300">
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-8">
            {t("about_advantage_title")}
          </h3>
        </div>

        <!-- Advantage Items -->
        <div class="space-y-6">
          <div 
            data-aos="fade-left" 
            data-aos-duration="1000" 
            data-aos-delay="400"
            class="bg-gradient-to-br from-purple-900/20 to-blue-900/20 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:border-purple-500/30 transition-all duration-300"
          >
            <h4 class="text-lg font-bold text-white mb-3 flex items-center gap-3">
              <div class="w-2 h-2 bg-gradient-to-r from-purple-400 to-blue-400 rounded-full"></div>
              {t("about_advantage1_title")}
            </h4>
            <p class="text-white/70 leading-relaxed">{t("about_advantage1_text")}</p>
          </div>

          <div 
            data-aos="fade-left" 
            data-aos-duration="1000" 
            data-aos-delay="500"
            class="bg-gradient-to-br from-purple-900/20 to-blue-900/20 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:border-purple-500/30 transition-all duration-300"
          >
            <h4 class="text-lg font-bold text-white mb-3 flex items-center gap-3">
              <div class="w-2 h-2 bg-gradient-to-r from-purple-400 to-blue-400 rounded-full"></div>
              {t("about_advantage2_title")}
            </h4>
            <p class="text-white/70 leading-relaxed">{t("about_advantage2_text")}</p>
          </div>

          <div 
            data-aos="fade-left" 
            data-aos-duration="1000" 
            data-aos-delay="600"
            class="bg-gradient-to-br from-purple-900/20 to-blue-900/20 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:border-purple-500/30 transition-all duration-300"
          >
            <h4 class="text-lg font-bold text-white mb-3 flex items-center gap-3">
              <div class="w-2 h-2 bg-gradient-to-r from-purple-400 to-blue-400 rounded-full"></div>
              {t("about_advantage3_title")}
            </h4>
            <p class="text-white/70 leading-relaxed">{t("about_advantage3_text")}</p>
          </div>

          <div 
            data-aos="fade-left" 
            data-aos-duration="1000" 
            data-aos-delay="700"
            class="bg-gradient-to-br from-purple-900/20 to-blue-900/20 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:border-purple-500/30 transition-all duration-300"
          >
            <h4 class="text-lg font-bold text-white mb-3 flex items-center gap-3">
              <div class="w-2 h-2 bg-gradient-to-r from-purple-400 to-blue-400 rounded-full"></div>
              {t("about_advantage4_title")}
            </h4>
            <p class="text-white/70 leading-relaxed">{t("about_advantage4_text")}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Background Elements -->
  <div class="absolute top-1/4 left-0 w-64 h-64 bg-purple-600/20 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-1/4 right-0 w-80 h-80 bg-blue-600/20 rounded-full blur-3xl -z-10"></div>
</section>