---
interface Props {
  lang: string;
}

const { lang } = Astro.props;

import { useTranslations } from "../i18n/utils";
const t = useTranslations(lang);
---

<section class="relative py-20 px-4 md:px-10 overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <!-- Main Title -->
    <div class="text-center mb-16" data-aos="fade-up" data-aos-duration="1000">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white">
        {t("about_foundation_title")}
      </h2>
      <p
        class="text-lg md:text-xl max-w-3xl mx-auto leading-relaxed"
        style="color: var(--text-body);"
      >
        {t("about_foundation_subtitle")}
      </p>
    </div>

    <!-- Content Grid -->
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left Column - Mission & Philosophy -->
      <div class="space-y-12">
        <!-- Mission -->
        <div
          data-aos="fade-right"
          data-aos-duration="1000"
          data-aos-delay="200"
        >
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-6">
            {t("about_mission_title")}
          </h3>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text-body);">
            {t("about_mission_text")}
          </p>
          <p class="text-lg leading-relaxed" style="color: var(--text-body);">
            {t("about_mission_text2")}
          </p>
        </div>

        <!-- Numbers Section -->
        <div
          data-aos="fade-right"
          data-aos-duration="1000"
          data-aos-delay="400"
          class="rounded-2xl p-8 backdrop-blur-xl"
          style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
        >
          <h4 class="text-xl font-bold text-white mb-6">
            {t("about_numbers_title")}
          </h4>
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center">
              <div class="text-3xl font-bold text-white mb-2">100%</div>
              <div class="text-sm" style="color: var(--text-body);">{t("about_number1")}</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-white mb-2">5+</div>
              <div class="text-sm" style="color: var(--text-body);">{t("about_number2")}</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-white mb-2">1-on-1</div>
              <div class="text-sm" style="color: var(--text-body);">{t("about_number3")}</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-white mb-2">100%</div>
              <div class="text-sm" style="color: var(--text-body);">{t("about_number4")}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column - Advantages -->
      <div class="space-y-8">
        <div data-aos="fade-left" data-aos-duration="1000" data-aos-delay="300">
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-8">
            {t("about_advantage_title")}
          </h3>
        </div>

        <!-- Advantage Items -->
        <div class="space-y-6">
          <div
            data-aos="fade-left"
            data-aos-duration="1000"
            data-aos-delay="400"
            class="rounded-xl p-6 backdrop-blur-xl transition-all duration-300"
            style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
          >
            <h4 class="text-lg font-bold text-white mb-3 flex items-center gap-3">
              <div class="w-2 h-2 bg-white rounded-full flex-shrink-0"></div>
              {t("about_advantage1_title")}
            </h4>
            <p class="leading-relaxed" style="color: var(--text-body);">
              {t("about_advantage1_text")}
            </p>
          </div>

          <div
            data-aos="fade-left"
            data-aos-duration="1000"
            data-aos-delay="500"
            class="rounded-xl p-6 backdrop-blur-xl transition-all duration-300"
            style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
          >
            <h4 class="text-lg font-bold text-white mb-3 flex items-center gap-3">
              <div class="w-2 h-2 bg-white rounded-full flex-shrink-0"></div>
              {t("about_advantage2_title")}
            </h4>
            <p class="leading-relaxed" style="color: var(--text-body);">
              {t("about_advantage2_text")}
            </p>
          </div>

          <div
            data-aos="fade-left"
            data-aos-duration="1000"
            data-aos-delay="600"
            class="rounded-xl p-6 backdrop-blur-xl transition-all duration-300"
            style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
          >
            <h4 class="text-lg font-bold text-white mb-3 flex items-center gap-3">
              <div class="w-2 h-2 bg-white rounded-full flex-shrink-0"></div>
              {t("about_advantage3_title")}
            </h4>
            <p class="leading-relaxed" style="color: var(--text-body);">
              {t("about_advantage3_text")}
            </p>
          </div>

          <div
            data-aos="fade-left"
            data-aos-duration="1000"
            data-aos-delay="700"
            class="rounded-xl p-6 backdrop-blur-xl transition-all duration-300"
            style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
          >
            <h4 class="text-lg font-bold text-white mb-3 flex items-center gap-3">
              <div class="w-2 h-2 bg-white rounded-full flex-shrink-0"></div>
              {t("about_advantage4_title")}
            </h4>
            <p class="leading-relaxed" style="color: var(--text-body);">
              {t("about_advantage4_text")}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
