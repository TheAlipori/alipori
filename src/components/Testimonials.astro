---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-16 px-4">
  <div class="flex flex-col items-center justify-center text-center mb-12">
    <h2
      data-aos="fade-down"
      data-aos-duration="1000"
      data-aos-easing="ease-out-cubic"
      class="max-w-lg mx-auto text-gray-500 mt-4 text-lg font-bold"
    >
      {t("testimonials1")}
    </h2>
    <h2
      data-aos="zoom-in"
      data-aos-duration="1000"
      data-aos-easing="ease-out-cubic"
      class="block w-full text-gray-900 font-bold text-4xl md:text-6xl"
    >
      {t("testimonials2")}
    </h2>
  </div>

  <div
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 max-w-6xl mx-auto"
  >
    <!-- Testimonio 1 -->
    <div
      data-aos="fade-up"
      data-aos-duration="1000"
      data-aos-delay="100"
      class="bg-brand-light/20 border border-brand-teal/40 rounded-2xl p-6 hover:border-brand hover:shadow-md transition-all duration-300 group"
    >
      <div class="flex items-center mb-4">
        <div
          class="w-12 h-12 bg-brand rounded-full flex items-center justify-center text-white font-bold text-lg"
        >
          {t("testimonial1_name").charAt(0)}
        </div>
        <div class="ml-4">
          <h4 class="text-gray-900 font-bold">{t("testimonial1_name")}</h4>
          <p class="text-gray-500 text-sm">{t("testimonial1_business")}</p>
        </div>
      </div>
      <div class="flex mb-4">
        {
          [1, 2, 3, 4, 5].map(() => (
            <svg
              class="w-5 h-5 text-yellow-400"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))
        }
      </div>
      <p class="text-gray-600 leading-relaxed">
        "{t("testimonial1_text")}"
      </p>
    </div>

    <!-- Testimonio 2 -->
    <div
      data-aos="fade-up"
      data-aos-duration="1000"
      data-aos-delay="200"
      class="bg-brand-light/20 border border-brand-teal/40 rounded-2xl p-6 hover:border-brand hover:shadow-md transition-all duration-300 group"
