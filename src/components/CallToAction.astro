---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import AliporiIcon from "../icons/AliporiIcon.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 px-4 overflow-x-hidden">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <h2
          data-aos="fade-right"
          data-aos-duration="1000"
          data-aos-easing="ease-out-cubic"
          class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 text-gray-900"
        >
          {t("cta1")}
        </h2>

        <p
          data-aos="fade-right"
          data-aos-duration="1000"
          data-aos-delay="200"
          class="text-xl md:text-2xl text-gray-600 mb-8 leading-relaxed"
        >
          {t("cta2")}
        </p>

        <div
          data-aos="fade-right"
          data-aos-duration="1000"
          data-aos-delay="400"
        >
          <a
            href="https://wa.me/5216182184762"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white transition-all duration-300 bg-brand rounded-full hover:bg-brand-dark hover:scale-105 shadow-lg"
          >
            <span class="flex items-center gap-3">
              {t("cta3")}
              <svg
                class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>

      <div
        data-aos="fade-left"
        data-aos-duration="1000"
        data-aos-delay="300"
        class="flex justify-center lg:justify-end"
      >
        <AliporiIcon
          class="w-48 h-48 md:w-64 md:h-64 lg:w-80 lg:h-80 transition-transform duration-300 hover:scale-110 fill-brand"
        />
      </div>
    </div>
  </div>
</section>
