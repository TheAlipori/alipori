---
interface Props {
  lang: string;
}

const { lang } = Astro.props;

import { useTranslations } from "../i18n/utils";
const t = useTranslations(lang);
---

<section class="relative py-20 px-4 md:px-10 overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <!-- Main Title -->
    <div class="text-center mb-16" data-aos="fade-up" data-aos-duration="1000">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white">
        {t("personal_profile_title")}
      </h2>
      <p class="text-lg md:text-xl max-w-3xl mx-auto leading-relaxed mb-4" style="color: var(--text-body);">
        {t("personal_intro")}
      </p>
      <p class="text-lg md:text-xl max-w-3xl mx-auto leading-relaxed" style="color: var(--text-body);">
        {t("personal_profile_subtitle")}
      </p>
    </div>

    <!-- Content Grid -->
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Education Card -->
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="200"
        class="rounded-2xl p-8 backdrop-blur-xl transition-all duration-300"
        style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
      >
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">{t("education_title")}</h3>
        </div>
        <div class="space-y-4">
          <div>
            <h4 class="text-lg font-semibold text-white mb-2">{t("degree_title")}</h4>
            <p class="leading-relaxed" style="color: var(--text-body);">{t("degree_description")}</p>
          </div>
          <div>
            <h4 class="text-sm font-medium text-white/70 mb-1">{t("specialization_title")}</h4>
            <p class="text-sm" style="color: var(--text-body);">{t("specialization_description")}</p>
          </div>
        </div>
      </div>

      <!-- Gaming Card -->
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="400"
        class="rounded-2xl p-8 backdrop-blur-xl transition-all duration-300"
        style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
      >
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1.01M15 10h1.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">{t("gaming_title")}</h3>
        </div>
        <div class="space-y-4">
          <p class="leading-relaxed" style="color: var(--text-body);">{t("gaming_description")}</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-white/10 text-white text-sm rounded-full">{t("gaming_skill1")}</span>
            <span class="px-3 py-1 bg-white/10 text-white text-sm rounded-full">{t("gaming_skill2")}</span>
            <span class="px-3 py-1 bg-white/10 text-white text-sm rounded-full">{t("gaming_skill3")}</span>
          </div>
        </div>
      </div>

      <!-- Hiking Card -->
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="600"
        class="rounded-2xl p-8 backdrop-blur-xl transition-all duration-300"
        style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
      >
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">{t("hiking_title")}</h3>
        </div>
        <div class="space-y-4">
          <p class="leading-relaxed" style="color: var(--text-body);">{t("hiking_description")}</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-white/10 text-white text-sm rounded-full">{t("hiking_skill1")}</span>
            <span class="px-3 py-1 bg-white/10 text-white text-sm rounded-full">{t("hiking_skill2")}</span>
            <span class="px-3 py-1 bg-white/10 text-white text-sm rounded-full">{t("hiking_skill3")}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Commitment Statement -->
    <div
      data-aos="fade-up"
      data-aos-duration="1000"
      data-aos-delay="800"
      class="mt-16 text-center"
    >
      <div
        class="rounded-2xl p-8 max-w-4xl mx-auto backdrop-blur-xl"
        style="background: linear-gradient(140deg, rgba(175,190,255,0.05), rgba(175,190,255,0.20));"
      >
        <h3 class="text-2xl font-bold text-white mb-4">{t("commitment_title")}</h3>
        <p class="text-lg leading-relaxed mb-6" style="color: var(--text-body);">{t("commitment_description")}</p>

        <div
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="900"
          class="mt-6"
        >
          <a
            href={`/cv-alipori-${lang}.pdf`}
            target="_blank"
            class="group inline-flex items-center justify-center px-6 py-3 text-base font-bold text-gray-900 transition-colors duration-300 bg-white hover:bg-white/80 rounded-xl"
          >
            <span class="flex items-center gap-3">
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              {t("cv_download_button")}
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
