---
import ExperienceIcon from "../icons/experienceIcon.astro";
import ProjectsIcon from "../icons/projectIcon.astro";
import IdIcon from "../icons/idcardIcon.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="aboutme"
  class="relative block px-6 mt-32 py-10 md:py-20 md:px-10 scroll-mt-16"
>
  <div
    data-aos="fade-up"
    data-aos-duration="1000"
    data-aos-easing="ease-out-cubic"
    class="relative mx-auto max-w-7xl z-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
  >
    <!-- Tarjeta 1 - Experiencia -->
    <div
      class="flex flex-col items-center rounded-xl p-8 bg-brand-light/20 border border-brand-teal/40 hover:border-brand hover:shadow-md transition-all duration-300 h-full"
    >
      <ExperienceIcon class="w-16 h-16 mb-6 fill-brand" />
      <h3 class="text-5xl font-bold text-brand mb-2">
        +4
      </h3>
      <p class="text-gray-600 font-medium text-lg">{t("cardabout1")}</p>
    </div>

    <!-- Tarjeta 2 - Proyectos -->
    <div
      class="flex flex-col items-center rounded-xl p-8 bg-brand-light/20 border border-brand-teal/40 hover:border-brand hover:shadow-md transition-all duration-300 h-full"
    >
      <ProjectsIcon class="w-16 h-16 mb-6 fill-brand" />
      <h3 class="text-5xl font-bold text-brand mb-2">
        +16
      </h3>
      <p class="text-gray-600 font-medium text-lg">{t("cardabout2")}</p>
    </div>

    <!-- Tarjeta 3 - ID Profesional -->
    <div
      class="flex flex-col items-center rounded-xl p-8 bg-brand-light/20 border border-brand-teal/40 hover:border-brand hover:shadow-md transition-all duration-300 h-full"
    >
      <IdIcon class="w-16 h-16 mb-6 fill-brand" />
      <h3 class="text-5xl font-bold text-brand mb-4">
        100%
      </h3>
      <p class="text-gray-600 font-medium text-lg leading-snug text-center">
        {t("cardabout3")}<br />
      </p>
    </div>
  </div>
</section>

<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const counterElement = document.getElementById("experienceCounter");
    let hasCounted = false;

    const animateCounter = () => {
      let count = 0;
      const target = 4;
      const duration = 1500;
      const fps = 60;
      const increment = target / (duration / (1000 / fps));

      const counter = setInterval(() => {
        count += increment;
        if (count >= target) {
          count = target;
          clearInterval(counter);
        }
        counterElement.textContent = `+${Math.floor(count)}`;
      }, 1000 / fps);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasCounted) {
            hasCounted = true;
            animateCounter();
          }
        });
      },
      { threshold: 0.5 }
    );

    observer.observe(counterElement);
  });
</script>
