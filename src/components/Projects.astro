---
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../i18n/utils";
import { languages } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatedPath = useTranslatedPath(lang);
---

<!-- Landing Pages Section -->
<section class="px-4 py-16 md:py-24 mx-auto max-w-7xl" ,id="projects">
  <div class="text-center mb-16">
    <h2 class="text-4xl md:text-5xl font-bold text-gray-900">
      {t("projects1")}
    </h2>
    <p class="mt-4 text-gray-500 max-w-xl mx-auto">
      {t("projects2")}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Landing 1 -->
    <div
      class="group relative rounded-xl overflow-hidden hover:shadow-xl transition-shadow border border-brand-teal/30"
    >
      <img
        src="/landingpagecafelibre.jpeg"
        alt="Proyecto 1"
        class="w-full h-64 object-cover transform group-hover:scale-105 transition-transform"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent p-6 flex flex-col justify-end"
      >
        <h3 class="text-xl font-bold text-white mb-2"></h3>
        <p class="text-gray-200 text-sm"></p>
        <a
          href={translatedPath("/projects")}
          class="font-bold mt-3 inline-block text-brand-light hover:text-white text-sm"
        >
          Aire Libre →
        </a>
      </div>
    </div>

    <!-- Landing 2 -->
    <div
      class="group relative rounded-xl overflow-hidden hover:shadow-xl transition-shadow border border-brand-teal/30"
    >
      <img
        src="/copymaxlandingpage.png"
        alt="Proyecto 2"
        class="w-full h-64 object-cover transform group-hover:scale-105 transition-transform"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent p-6 flex flex-col justify-end"
      >
        <h3 class="text-xl font-bold text-white mb-2"></h3>
        <p class="text-gray-200 text-sm"></p>
        <a
          href={translatedPath("/projects")}
          class="font-bold mt-3 inline-block text-brand-light hover:text-white text-sm"
        >
          Copymax →
        </a>
      </div>
    </div>

    <!-- Landing 3 -->
    <div
      class="group relative rounded-xl overflow-hidden hover:shadow-xl transition-shadow border border-brand-teal/30"
    >
      <img
        src="/landingpage.png"
        alt="Proyecto 3"
        class="w-full h-64 object-cover transform group-hover:scale-105 transition-transform"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent p-6 flex flex-col justify-end"
      >
        <h3 class="text-xl font-bold text-white mb-2"></h3>
        <p class="text-gray-200 text-sm"></p>
        <a
          href={translatedPath("/projects")}
          class="font-bold mt-3 inline-block text-brand-light hover:text-white text-sm"
        >
          FunPet
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Branding Section -->
<section class="px-4 py-16 md:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900">
        {t("projects3")}
      </h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        {t("projects4")}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Branding 1 -->
      <div
        class="group relative rounded-xl overflow-hidden bg-brand-light/20 border border-brand-teal/30 hover:shadow-lg transition-shadow"
      >
        <img
          src="/rebranding-1.png"
          alt="Branding 1"
          class="w-full h-96 object-contain p-8 transform group-hover:scale-[1.02] transition-transform"
        />
        <div class="p-6 border-t border-brand-teal/30">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Copymax</h3>
          <p class="text-gray-500 text-sm">{t("projects5")}</p>
        </div>
      </div>

      <!-- Branding 2 -->
      <div
        class="group relative rounded-xl overflow-hidden bg-brand-light/20 border border-brand-teal/30 hover:shadow-lg transition-shadow"
      >
        <img
          src="/airelibre.png"
          alt="Branding 2"
          class="w-full h-96 object-contain p-8 transform group-hover:scale-[1.02] transition-transform"
        />
        <div class="p-6 border-t border-brand-teal/30">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Aire Libre</h3>
          <p class="text-gray-500 text-sm">{t("projects7")}</p>
        </div>
      </div>
    </div>
  </div>
</section>
