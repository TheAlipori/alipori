---
import AliporiIcon from "../icons/AliporiIcon.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import SelectLang from "./SelectLang.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="mx-auto w-full max-w-container px-4 sm:px-6 lg:px-8">
  <div class="border-t border-brand-teal/30 py-10">
    <AliporiIcon class="mx-auto h-24 w-auto fill-brand" />
    <p class="mt-5 text-center text-sm leading-6 text-gray-500">
      © 2025 Alipori. :_)
    </p>
    <div
      class="mt-8 flex items-center justify-center space-x-4 text-sm font-semibold leading-6 text-gray-500"
    >
      <a href="/privacy-policy" class="hover:text-brand transition-colors">{t("footer1")}</a>
      <div class="h-4 w-px bg-brand-teal/40"></div>
      <a href="https://wa.me/5216182184762" class="hover:text-brand transition-colors">{t("footer2")}</a>
    </div>
  </div>
  <SelectLang />
</footer>
