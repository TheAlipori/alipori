---
interface Props {
  lang: string;
}

const { lang } = Astro.props;

import { useTranslations } from "../i18n/utils";
const t = useTranslations(lang);
---

<section
  class="relative px-4 py-12 md:py-0 md:px-10 overflow-hidden overflow-x-hidden"
>
  <div
    class="flex flex-col justify-center items-center min-h-screen gap-8 max-w-4xl mx-auto text-center"
  >
    <div class="z-10">
      <div data-aos="zoom-in" data-aos-duration="1000">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 text-white">
          {t("about_hero_title")}
        </h1>

        <p class="text-lg md:text-xl mb-8 max-w-2xl mx-auto leading-relaxed" style="color: var(--text-body);">
          {t("about_hero_subtitle")}
        </p>
      </div>

      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="300"
        class="mt-8"
      >
        <a
          href="https://wa.me/5216182184762"
          class="group inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-gray-900 transition-colors duration-300 bg-white hover:bg-white/80 rounded-full"
        >
          <span class="flex items-center gap-3">
            {t("about_hero_button")}
            <svg
              class="w-5 h-5 transition-transform duration-300 group-hover:rotate-12"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
