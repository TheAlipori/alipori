---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="min-h-screen flex items-center justify-center px-4 py-20">
  <div class="text-center max-w-4xl mx-auto">

    <h1
      data-aos="zoom-in"
      data-aos-duration="1000"
      data-aos-easing="ease-out-cubic"
      class="text-5xl md:text-6xl lg:text-8xl font-bold mb-8 text-white leading-tight"
    >
      {t('portfolio_hero1')}
    </h1>

    <div
      data-aos="fade-up"
      data-aos-duration="1000"
      data-aos-delay="400"
      class="mt-12"
    >
      <a
        href="https://wa.me/5216182184762"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-gray-900 transition-colors duration-300 bg-white hover:bg-white/80 rounded-full"
      >
        <span class="flex items-center gap-3">
          {t('portfolio_hero2')}
          <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </span>
      </a>
    </div>

  </div>
</section>
